task.spawn(function()
    while true do
        DynamicColor = Color3.fromHSV(tick() % 6 / 6, 0.8, 1)
        if VisualFlags.DiurnalTimeLock then Lighting.ClockTime = 12 end
        if VisualFlags.GlitchScreenEffect then
            local cc = Lighting:FindFirstChild("HolyCC")
            if cc then cc.Contrast = math.random(10, 30) / 15 end
            task.wait(0.04)
        end
        if VisualFlags.ColorTintShift then
            local cc = Lighting:FindFirstChild("HolyCC") or Instance.new("ColorCorrectionEffect", Lighting)
            cc.Name = "HolyCC"; cc.TintColor = DynamicColor
        end
        task.wait()
    end
end)

local BaseFOV = Camera.FieldOfView
local lastPos = Vector3.new(0,0,0)

RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    -- Motion Blur Handler
    if VisualFlags.MotionBlurLens and hrp then
        local vel = (hrp.Position - lastPos).Magnitude / task.wait()
        lastPos = hrp.Position
        Camera.FieldOfView = BaseFOV + math.clamp(vel / 4, 0, 20)
    else
        if not VisualFlags.PixelationShader then
            Camera.FieldOfView = BaseFOV
        end
    end
    
    -- Chromatic Shifter Handler
    if VisualFlags.ChromaticAberration then
        Camera.CFrame = Camera.CFrame * CFrame.new(math.sin(tick()*10)*0.02, 0, 0)
    end

    -- Drunk Lens Wobble FOV Handler
    if VisualFlags.PixelationShader then
        Camera.FieldOfView = BaseFOV + (math.sin(os.clock() * 5) * 10)
    end
    
    -- Rainbow Torso Handler
    if VisualFlags.RainbowTorsoCycle and char then
        local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
        if torso then torso.Color = DynamicColor end
    end
end)

-- Character Aura Mesh Engine Link
local function spawnAura(character)
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end
    local orb = Instance.new("Part")
    orb.Size = Vector3.new(1.2, 1.2, 1.2); orb.Shape = Enum.PartType.Ball; orb.Material = Enum.Material.Neon
    orb.CanCollide, orb.Anchored, orb.Parent = false, true, HolyVisualzMatrix
    
    local oLoop = RunService.RenderStepped:Connect(function()
        if not hrp or not hrp.Parent then return end
        if VisualFlags.OrbitEnergyOrbs then
            orb.Transparency = 0; orb.Color = DynamicColor
            orb.CFrame = hrp.CFrame * CFrame.new(math.sin(os.clock()*4)*4, math.sin(os.clock()*2), math.cos(os.clock()*4)*4)
        else orb.Transparency = 1 end
    end)
    character.Humanoid.Died:Connect(function() oLoop:Disconnect(); orb:Destroy() end)
end
if LocalPlayer.Character then task.spawn(spawnAura, LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(spawnAura)
