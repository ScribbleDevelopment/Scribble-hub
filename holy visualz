local function targetScan(txt)
    if txt == "" then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Name:lower():sub(1, #txt) == txt:lower() then return p end
    end
    return nil
end

DecapSec:NewTextBox("Input Target Signature", "Locks character references for visual manipulation", function(t)
    ActiveTargetPlayer = targetScan(t)
end)

DecapSec:NewButton("Drop Target Head", "Detaches target head joints client-sided instantly", function()
    local target = ActiveTargetPlayer
    if not target or not target.Character then return end
    local head = target.Character:FindFirstChild("Head")
    local neck = target.Character:FindFirstChild("Neck") or (target.Character:FindFirstChild("Torso") and target.Character.Torso:FindFirstChild("Neck")) or (target.Character:FindFirstChild("UpperTorso") and target.Character.UpperTorso:FindFirstChild("Neck"))
    
    if head and head:IsA("BasePart") and neck and neck:IsA("Motor6D") then
        NeckCache[target] = { Parent = neck.Parent, Part0 = neck.Part0, Part1 = neck.Part1, C0 = neck.C0, C1 = neck.C1, Name = neck.Name }
        neck:Destroy()
        head.CanCollide, head.Anchored = true, false
        head.Velocity = (head.CFrame.LookVector * 15) + Vector3.new(0, 5, 0)
    end
end)

DecapSec:NewButton("Restore Target Head", "Re-welds neck joints back to baseline coordinate systems", function()
    local target = ActiveTargetPlayer
    if not target or not NeckCache[target] then return end
    local cache = NeckCache[target]
    if target.Character and cache.Parent then
        local n = Instance.new("Motor6D")
        n.Name = cache.Name; n.Part0 = cache.Part0; n.Part1 = cache.Part1; n.C0 = cache.C0; n.C1 = cache.C1; n.Parent = cache.Parent
        if target.Character:FindFirstChild("Head") then target.Character.Head.CanCollide = false end
        NeckCache[target] = nil
    end
end)

