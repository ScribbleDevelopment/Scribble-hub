-- --- CONFIGURATION ENFORCEMENT LOOP ---
local function enforceState()
    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        if speedEnabled then
            humanoid.WalkSpeed = 50
        else
            humanoid.WalkSpeed = 16
        end
    end
end

player.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid", 5)
    task.wait(0.1)
    enforceState()
end)

RunService.PostSimulation:Connect(enforceState)


-- --- ACTION FUNCTIONS ---

local function parseCoordinates(text)
    local coords = {}
    for num in string.gmatch(text, "%-?%d+%.?%d*") do
        table.insert(coords, tonumber(num))
    end
    return coords
end

-- Teleport Setup
tpButton.MouseButton1Click:Connect(function()
    local text = inputBox.Text
    local coords = parseCoordinates(text)
    
    if #coords >= 3 then
        local targetPosition = Vector3.new(coords[1], coords[2], coords[3])
        local character = player.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        
        if root then
            if baseWiperEnabled then
                task.spawn(function()
                    local originalPosition = root.CFrame
                    root.CFrame = CFrame.new(targetPosition)
                    task.wait(0.02)
                    enforceState()
                    
                    task.wait(0.3)
                    
                    if root and root.Parent then
                        root.CFrame = originalPosition
                        task.wait(0.02)
                        enforceState()
                    end
                end)
            else
                root.CFrame = CFrame.new(targetPosition)
                task.wait(0.02)
                enforceState()
            end
        end
    else
        local originalText = tpButton.Text
        tpButton.Text = "Invalid Form!"
        tpButton.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
        task.wait(1.5)
        tpButton.Text = originalText
        tpButton.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    end
end)

