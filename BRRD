local slotButtons = {}

-- Helper to set the text layout correctly for Slot 1 vs others
local function updateSlotText(slotNum)
    local status = (savedSlots[slotNum] == "") and "[Empty]" or "[Saved]"
    if slotNum == 1 then
        slotButtons[1].Text = "Slot 1\n" .. status .. "\n[Set this to your base]"
    else
        slotButtons[slotNum].Text = "Slot " .. slotNum .. "\n" .. status
    end
end

-- Update UI backgrounds when active slot transitions
local function refreshSlotVisuals()
    for i = 1, 10 do
        if slotButtons[i] then
            if i == activeSlot then
                slotButtons[i].BackgroundColor3 = Color3.fromRGB(200, 60, 60)
            else
                slotButtons[i].BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            end
        end
    end
end

-- Generate the 10 slot elements inside the ScrollingFrame
for i = 1, 10 do
    local sButton = Instance.new("TextButton")
    styleElement(sButton, UDim2.new(0, 115, 0, 45), UDim2.new(0, 5, 0, (i - 1) * 55 + 5), "", Color3.fromRGB(50, 50, 50), scrollFrame)
    sButton.TextSize = 11
    slotButtons[i] = sButton
    
    updateSlotText(i)
    
    sButton.MouseButton1Click:Connect(function()
        activeSlot = i
        inputBox.Text = savedSlots[i]
        refreshSlotVisuals()
    end)
end
refreshSlotVisuals()

-- Keep the inputBox dynamically synced with changes
inputBox:GetPropertyChangedSignal("Text"):Connect(function()
