    neck = character:FindFirstChild("Neck", true)
    waist = character:FindFirstChild("Waist", true)
    
    origRS = rightShoulder and rightShoulder.C0 or CFrame.new()
    origLS = leftShoulder and leftShoulder.C0 or CFrame.new()
    origNeck = neck and neck.C0 or CFrame.new()
    origWaist = waist and waist.C0 or CFrame.new()
    
    if danceActive and (currentDanceIndex == 1 or currentDanceIndex == 3) then
        humanoid.AutoRotate = false
    end
end)

-- Core Procedural Physics Loop
RunService.Stepped:Connect(function()
    if not character or not character:IsDescendantOf(game.Workspace) or humanoid.Health <= 0 then return end
    
    if danceActive then
        if currentDanceIndex == 1 or currentDanceIndex == 3 then
            humanoid.AutoRotate = false
        else
            humanoid.AutoRotate = true
        end
        danceDatabase[currentDanceIndex].Update()
    else
        humanoid.AutoRotate = true
        if rightShoulder then rightShoulder.C0 = rightShoulder.C0:Lerp(origRS, 0.2) end
        if leftShoulder then leftShoulder.C0 = leftShoulder.C0:Lerp(origLS, 0.2) end
        if neck then neck.C0 = neck.C0:Lerp(origNeck, 0.2) end
        if waist then waist.C0 = waist.C0:Lerp(origWaist, 0.2) end
    end
end)

