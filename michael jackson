-- Character Custom Physics Dance Profiles
local danceDatabase = {
    {
        Name = "Classic Moonwalk",
        Update = function()
            if humanoid.MoveDirection.Magnitude > 0.1 and humanoid:GetState() == Enum.HumanoidStateType.Running then
                local moveDir = humanoid.MoveDirection
                rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.lookAt(rootPart.Position, rootPart.Position - moveDir), 0.25)
                if rightShoulder then rightShoulder.C0 = origRS * CFrame.Angles(math.rad(145), math.rad(-35), math.rad(-25)) end
                if leftShoulder then leftShoulder.C0 = origLS * CFrame.Angles(math.rad(-10), 0, math.rad(-15)) end
                if neck then neck.C0 = origNeck * CFrame.Angles(math.rad(-10), 0, 0) end
                if waist then waist.C0 = origWaist * CFrame.Angles(math.rad(10), 0, 0) end
            else
                if rightShoulder then rightShoulder.C0 = rightShoulder.C0:Lerp(origRS, 0.2) end
                if leftShoulder then leftShoulder.C0 = leftShoulder.C0:Lerp(origLS, 0.2) end
                if neck then neck.C0 = neck.C0:Lerp(origNeck, 0.2) end
                if waist then waist.C0 = waist.C0:Lerp(origWaist, 0.2) end
            end
        end
    },
    {
        Name = "45-Degree Lean",
        Update = function()
            if rightShoulder then rightShoulder.C0 = origRS * CFrame.Angles(math.rad(-20), 0, math.rad(15)) end
            if leftShoulder then leftShoulder.C0 = origLS * CFrame.Angles(math.rad(-20), 0, math.rad(-15)) end
            if neck then neck.C0 = origNeck * CFrame.Angles(math.rad(-15), 0, 0) end
            if waist then waist.C0 = origWaist * CFrame.Angles(math.rad(35), 0, 0) end
        end
    },
    {
        Name = "Smooth Slide Glide",
        Update = function()
            local wave = math.sin(os.clock() * 10)
            if humanoid.MoveDirection.Magnitude > 0.1 then
                local moveDir = humanoid.MoveDirection
                rootPart.CFrame = rootPart.CFrame:Lerp(CFrame.lookAt(rootPart.Position, rootPart.Position - moveDir), 0.25)
            end
            if rightShoulder then rightShoulder.C0 = origRS * CFrame.Angles(math.rad(-10), 0, math.rad(20 + wave * 15)) end
            if leftShoulder then leftShoulder.C0 = origLS * CFrame.Angles(math.rad(-10), 0, math.rad(-20 + wave * 15)) end
            if neck then neck.C0 = origNeck * CFrame.Angles(0, 0, math.rad(wave * 8)) end
            if waist then waist.C0 = origWaist * CFrame.Angles(0, math.rad(wave * 12), 0) end
        end
    },
    {
        Name = "Side Toe Stand Toe Snap",
        Update = function()
            local t = os.clock() * 12
            local pop = math.abs(math.sin(t)) * 0.4
            if rightShoulder then rightShoulder.C0 = origRS * CFrame.new(0, pop, 0) * CFrame.Angles(math.rad(15), 0, math.rad(25)) end
            if leftShoulder then leftShoulder.C0 = origLS * CFrame.new(0, pop, 0) * CFrame.Angles(math.rad(-30), math.rad(-20), math.rad(-20)) end
            if neck then neck.C0 = origNeck * CFrame.Angles(math.rad(10), math.rad(15 * math.sin(t)), 0) end
            if waist then waist.C0 = origWaist * CFrame.new(0, pop, 0) * CFrame.Angles(0, 0, math.rad(-8)) end
        end
    },
    {
        Name = "Spin & Pose Shaker",
        Update = function()
            local speed = 14
            local wave = math.sin(os.clock() * speed)
            if rightShoulder then rightShoulder.C0 = origRS * CFrame.Angles(math.rad(90 + wave * 20), 0, math.rad(-30)) end
            if leftShoulder then leftShoulder.C0 = origLS * CFrame.Angles(math.rad(90 - wave * 20), 0, math.rad(30)) end
            if neck then neck.C0 = origNeck * CFrame.Angles(math.rad(wave * 10), 0, 0) end
            if waist then waist.C0 = origWaist * CFrame.Angles(0, math.rad(wave * 25), 0) end
        end
    }
}

local function stopSingingLogic()
    if singingThread then
        task.cancel(singingThread)
        singingThread = nil
    end
end

local function getFullTxtLyrics(url)
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)
    if success and response and string.find(response, "404: Not Found") == nil then
        local lines = {}
        for line in string.gmatch(response, "[^\r\n]+") do
            local cleanLine = string.gsub(line, "^%s*(.-)%s*$", "%1")
            if #cleanLine > 0 then
                table.insert(lines, cleanLine)
            end
        end
        return lines
    else
        warn("MJ Script Error: 404 target path connection dropped. Check exact repo url characters.")
    end
    return nil
end

local function startSingingLogic()
    stopSingingLogic()
    
    local trackData = songDatabase[currentSongIndex]
    local targetLyrics = trackData.ShortLyrics
    
    if useFullSong then
        -- Corrected Spelling to 'michaeljackson' to perfectly sync with your absolute path
        local fullUrl = "https://raw.githubusercontent.com/ScribbleDevelopment/UniqueLyric/refs/heads/master/lyrics/michaeljackson/" .. trackData.File .. ".txt"
        local fetched = getFullTxtLyrics(fullUrl)
        if fetched and #fetched > 0 then
            targetLyrics = fetched
        else
            targetLyrics = {"[Script Error: Re-evaluating text link alignment...]"}
        end
    end
    
    singingThread = task.spawn(function()
        local textChannel = TextChatService:FindFirstChild("RBXGeneral", true) or TextChatService.TextChannels:FindFirstChild("RBXGeneral")
        local activeTrackName = trackData.Name
        
        repeat
            for _, lineText in ipairs(targetLyrics) do
                if not isSinging or trackData.Name ~= activeTrackName then break end
                
                if textChannel then
                    textChannel:SendAsync(lineText)
                else
                    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(lineText, "All")
                end
                
                -- Dynamic anti-spam throttler delay window to safely run through huge lists without filtering
                task.wait(4.2)
            end
            if isSinging and isLooped and trackData.Name == activeTrackName then
                task.wait(2)
            end
        until not isSinging or not isLooped or trackData.Name ~= activeTrackName
        
        if isSinging and not isLooped and trackData.Name == activeTrackName then
            isSinging = false
            local uiRoot = localPlayer:WaitForChild("PlayerGui", 5) or game:GetService("CoreGui")
            local Frame = uiRoot:FindFirstChild("MJControlHub", true)
            if Frame then
                local StatusIndicator = Frame:FindFirstChild("StatusIndicator", true)
                if StatusIndicator then
                    StatusIndicator.Text = "Singing Status: Idle"
                    StatusIndicator.TextColor3 = Color3.fromRGB(180, 180, 180)
                end
            end
        end
    end)
end

