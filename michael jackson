    useFullSong = not useFullSong
    if useFullSong then
        LengthToggleBtn.Text = "Length: Full Song"
        LengthToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 30, 80)
    else
        LengthToggleBtn.Text = "Length: Good Parts"
        LengthToggleBtn.BackgroundColor3 = Color3.fromRGB(160, 20, 120)
    end
    
    if isSinging then
        startSingingLogic()
    end
end)

LoopToggleBtn.MouseButton1Click:Connect(function()
    isLooped = not isLooped
    if isLooped then
        LoopToggleBtn.Text = "Looping: ON"
        LoopToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 150)
    else
        LoopToggleBtn.Text = "Looping: OFF"
        LoopToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 75, 40)
    end
end)

StartSingBtn.MouseButton1Click:Connect(function()
    if not isSinging then
        isSinging = true
        StatusIndicator.Text = "Singing Status: Active"
        StatusIndicator.TextColor3 = Color3.fromRGB(50, 220, 110)
        startSingingLogic()
    end
end)

StopSingBtn.MouseButton1Click:Connect(function()
    if isSinging then
        isSinging = false
        StatusIndicator.Text = "Singing Status: Idle"
        StatusIndicator.TextColor3 = Color3.fromRGB(180, 180, 180)
        stopSingingLogic()
    end
end)

local CoreGui = game:GetService("CoreGui")
local success, err = pcall(function()
    ScreenGui.Parent = CoreGui
end)
if not success then
    ScreenGui.Parent = localPlayer:WaitForChild("PlayerGui")
end
